{
  "name": "@eyalm321/porkbun-mcp",
  "version": "1.0.0",
  "description": "MCP server for Porkbun API v3 — domain registration, DNS management, SSL certificates, and more",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "bin": {
    "porkbun-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "porkbun",
    "dns",
    "domain",
    "ssl",
    "claude",
    "model-context-protocol"
  ],
  "author": "Eyalm321",
  "repository": {
    "type": "git",
    "url": "https://github.com/Eyalm321/porkbun-mcp.git"
  },
  "homepage": "https://github.com/Eyalm321/porkbun-mcp#readme",
  "bugs": {
    "url": "https://github.com/Eyalm321/porkbun-mcp/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
